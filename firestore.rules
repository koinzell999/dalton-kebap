rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /{allPaths=**} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Daily order counter — monotonically incrementing, resets only on date change.
    match /counters/{counterId} {
      allow read: if true;
      allow write: if counterId == 'daily'
          && request.resource.data.keys().hasAll(['date','count'])
          && request.resource.data.count is int
          && request.resource.data.count > 0
          && request.resource.data.date  is string
          && (
               resource == null                                           // first write ever
            || request.resource.data.date != resource.data.date          // new day → reset to any positive int
            || request.resource.data.count == resource.data.count + 1    // same day → only +1 allowed
             );
    }

    match /orders/{orderId} {
      allow create: if validOrderCreate();
      allow read:   if true;
      allow update: if validStatusUpdate() || validOrderEdit();
      allow delete: if false;
    }

    function validOrderCreate() {
      let d = request.resource.data;
      return d.keys().hasAll(['table_id','order_items','total_price','status','timestamp','session_id','order_number'])
          && d.status       == 'pending'
          && d.table_id     is int    && d.table_id >= 1 && d.table_id <= 13
          && d.order_items  is list   && d.order_items.size() > 0 && d.order_items.size() <= 50
          && d.total_price  is number && d.total_price > 0
          && d.session_id   is string && d.session_id.size() > 0
          && d.order_number is int    && d.order_number > 0;
    }

    // Allowed status transitions:
    //   Kitchen: pending → served
    //   Kitchen: pending → cancelled  (item unavailable / reject)
    //   Cashier: served  → paid
    //   Cashier: pending → paid       (force-close, e.g. whole table at once)
    function validStatusUpdate() {
      let from = resource.data.status;
      let to   = request.resource.data.status;
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
          && (
               (from == 'pending' && to == 'served')    ||
               (from == 'pending' && to == 'cancelled') ||
               (from == 'pending' && to == 'paid')      ||
               (from == 'served'  && to == 'paid')
             );
    }

    // Customer edits items/total while order is still pending (10-min window enforced client-side).
    function validOrderEdit() {
      let current = resource.data;
      let d       = request.resource.data;
      return current.status == 'pending'
          && d.diff(current).affectedKeys().hasOnly(['order_items','total_price'])
          && d.order_items is list && d.order_items.size() > 0 && d.order_items.size() <= 50
          && d.total_price is number && d.total_price > 0;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
