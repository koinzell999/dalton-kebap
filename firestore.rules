rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /{allPaths=**} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Daily order counter — monotonically incrementing, resets only on date change.
    match /counters/{counterId} {
      allow read: if true;
      allow write: if counterId == 'daily'
          && request.resource.data.keys().hasAll(['date','count'])
          && request.resource.data.count is int
          && request.resource.data.count > 0
          && request.resource.data.date  is string
          && (
               resource == null
            || request.resource.data.date != resource.data.date
            || request.resource.data.count == resource.data.count + 1
             );
    }

    match /orders/{orderId} {
      allow create: if validOrderCreate();
      allow read:   if true;
      allow update: if validStatusUpdate() || validOrderEdit();
      allow delete: if false;
    }

    function validOrderCreate() {
      let d = request.resource.data;
      return d.keys().hasAll(['table_id','order_items','total_price','status','timestamp','session_id','order_number'])
          && d.status       == 'pending'
          && d.table_id     is int    && d.table_id >= 1 && d.table_id <= 13
          && d.order_items  is list   && d.order_items.size() > 0 && d.order_items.size() <= 50
          && d.total_price  is number && d.total_price > 0
          && d.session_id   is string && d.session_id.size() > 0
          && d.order_number is int    && d.order_number > 0
          // Notes are optional but capped at 300 chars to prevent abuse
          && (!d.keys().hasAll(['notes']) || d.notes.size() <= 300);
    }

    // Allowed status transitions — PIN gates on the staff panels control access.
    // Anonymous Firebase auth is not used (disabled in this project); the state
    // machine below is the security control: valid from/to pairs and restricted
    // field changes prevent status skipping or forging.
    function validStatusUpdate() {
      let from    = resource.data.status;
      let to      = request.resource.data.status;
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let isCancellation = (from == 'pending' || from == 'preparing') && to == 'cancelled';
      return (
        changed.hasOnly(['status']) ||
        (isCancellation && changed.hasOnly(['status', 'cancel_reason']))
      ) && (
           (from == 'pending'   && to == 'preparing')  ||  // kitchen: acknowledge
           (from == 'pending'   && to == 'cancelled' ) ||  // kitchen/customer: reject
           (from == 'preparing' && to == 'served'   )  ||  // kitchen: food ready
           (from == 'preparing' && to == 'cancelled' ) ||  // kitchen: abort mid-prep
           (from == 'pending'   && to == 'paid'      ) ||  // cashier: force-close
           (from == 'preparing' && to == 'paid'      ) ||  // cashier: force-close
           (from == 'served'    && to == 'paid'      )     // cashier: normal payment
      );
    }

    // Customer edits items/total/notes while order is still pending.
    // Edit window (10 min) is now also enforced server-side via timestamp.
    function validOrderEdit() {
      let current = resource.data;
      let d       = request.resource.data;
      return current.status == 'pending'
          && request.time < resource.data.timestamp + duration.value(10, 'm')
          && d.diff(current).affectedKeys().hasOnly(['order_items','total_price','notes'])
          && d.order_items is list && d.order_items.size() > 0 && d.order_items.size() <= 50
          && d.total_price is number && d.total_price > 0
          && (!d.keys().hasAll(['notes']) || d.notes.size() <= 300);
    }

    // Waiter call notifications — customers create; waiter panel (authenticated) deletes.
    match /waiter_calls/{callId} {
      allow read:   if true;
      allow create: if request.resource.data.keys().hasAll(['table_id','timestamp'])
          && request.resource.data.table_id is int
          && request.resource.data.table_id >= 1
          && request.resource.data.table_id <= 13;
      allow delete: if true;  // waiter panel marks calls resolved; PIN gate controls access
      allow update: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
