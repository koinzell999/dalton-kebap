rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /{allPaths=**} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Daily order counter — monotonically incrementing, resets only on date change.
    match /counters/{counterId} {
      allow read: if true;
      allow write: if counterId == 'daily'
          && request.resource.data.keys().hasAll(['date','count'])
          && request.resource.data.count is int
          && request.resource.data.count > 0
          && request.resource.data.date  is string
          && (
               resource == null
            || request.resource.data.date != resource.data.date
            || request.resource.data.count == resource.data.count + 1
             );
    }

    match /orders/{orderId} {
      allow create: if validOrderCreate();
      allow read:   if true;
      allow update: if validStatusUpdate() || validOrderEdit();
      allow delete: if false;
    }

    function validOrderCreate() {
      let d = request.resource.data;
      return d.keys().hasAll(['table_id','order_items','total_price','status','timestamp','session_id','order_number'])
          && d.status       == 'pending'
          && d.table_id     is int    && d.table_id >= 1 && d.table_id <= 13
          && d.order_items  is list   && d.order_items.size() > 0 && d.order_items.size() <= 50
          && d.total_price  is number && d.total_price > 0
          && d.session_id   is string && d.session_id.size() > 0
          && d.order_number is int    && d.order_number > 0;
    }

    // Allowed status transitions:
    //   Kitchen: pending → served
    //   Kitchen: pending → cancelled  (with optional cancel_reason)
    //   Cashier: served  → paid
    //   Cashier: pending → paid       (force-close whole table)
    function validStatusUpdate() {
      let from    = resource.data.status;
      let to      = request.resource.data.status;
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let isCancellation = from == 'pending' && to == 'cancelled';
      return (
        changed.hasOnly(['status']) ||
        (isCancellation && changed.hasOnly(['status', 'cancel_reason']))
      ) && (
           (from == 'pending' && to == 'served')    ||
           (from == 'pending' && to == 'cancelled') ||
           (from == 'pending' && to == 'paid')      ||
           (from == 'served'  && to == 'paid')
      );
    }

    // Customer edits items/total/notes while order is still pending (10-min window enforced client-side).
    function validOrderEdit() {
      let current = resource.data;
      let d       = request.resource.data;
      return current.status == 'pending'
          && d.diff(current).affectedKeys().hasOnly(['order_items','total_price','notes'])
          && d.order_items is list && d.order_items.size() > 0 && d.order_items.size() <= 50
          && d.total_price is number && d.total_price > 0;
    }

    // Waiter call notifications — customers create, waiter panel deletes after acknowledging.
    match /waiter_calls/{callId} {
      allow read:   if true;
      allow create: if request.resource.data.keys().hasAll(['table_id','timestamp'])
          && request.resource.data.table_id is int
          && request.resource.data.table_id >= 1
          && request.resource.data.table_id <= 13;
      allow delete: if true;
      allow update: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
