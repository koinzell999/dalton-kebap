rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /{allPaths=**} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Daily order counter — atomically incremented per order
    match /counters/{counterId} {
      allow read, write: if true;
    }

    match /orders/{orderId} {
      allow create: if validOrderCreate();
      allow read:   if true;
      allow update: if validStatusUpdate() || validOrderEdit();
      allow delete: if false;
    }

    function validOrderCreate() {
      let d = request.resource.data;
      return d.keys().hasAll(['table_id','order_items','total_price','status','timestamp','session_id','order_number'])
          && d.status       == 'pending'
          && d.table_id     is int   && d.table_id >= 1 && d.table_id <= 13
          && d.order_items  is list  && d.order_items.size() > 0 && d.order_items.size() <= 50
          && d.total_price  is number && d.total_price > 0
          && d.session_id   is string && d.session_id.size() > 0
          && d.order_number is int   && d.order_number > 0;
    }

    // Kitchen: pending → served.  Cashier: served → paid.
    function validStatusUpdate() {
      let current = resource.data.status;
      let next    = request.resource.data.status;
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
          && (
               (current == 'pending' && next == 'served') ||
               (current == 'served'  && next == 'paid')
             );
    }

    // Customer edits items while order is still pending (within the 10-min window enforced client-side)
    function validOrderEdit() {
      let current = resource.data;
      let d       = request.resource.data;
      return current.status == 'pending'
          && d.diff(current).affectedKeys().hasOnly(['order_items','total_price'])
          && d.order_items is list && d.order_items.size() > 0 && d.order_items.size() <= 50
          && d.total_price is number && d.total_price > 0;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
