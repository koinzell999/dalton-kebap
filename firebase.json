{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/kitchen",      "destination": "/kitchen.html" },
      { "source": "/kitchen.html", "destination": "/kitchen.html" },
      { "source": "/cashier",      "destination": "/cashier.html" },
      { "source": "/cashier.html", "destination": "/cashier.html" },
      { "source": "/waiter",       "destination": "/waiter.html" },
      { "source": "/waiter.html",  "destination": "/waiter.html" },
      { "source": "**",            "destination": "/index.html" }
    ]
  }
}
